# OpenAI API (used for chat fallback + TTS fallback)
OPENAI_API_KEY=

# Replicate API (Gemini chat/voice + Whisper STT + Chatterbox TTS)
REPLICATE_API_TOKEN=

# Optional: Sentry
SENTRY_AUTH_TOKEN=
SENTRY_DSN=
