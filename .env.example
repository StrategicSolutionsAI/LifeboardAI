# Todoist OAuth
TODOIST_CLIENT_ID=
TODOIST_CLIENT_SECRET=

# Withings OAuth
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=

# Google OAuth (Calendar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Anthropic API (Claude Fable 5 — primary model for the dashboard chat)
