# Todoist Integration Configuration
# Get these from: https://developer.todoist.com/appconsole.html

# Create a new app in Todoist Developer Console
TODOIST_CLIENT_ID=your_client_id_here
TODOIST_CLIENT_SECRET=your_client_secret_here

# Make sure your redirect URI in Todoist console is:
# http://localhost:3000/api/integrations/todoist/auth (for development)
# https://yourdomain.com/api/integrations/todoist/auth (for production)

# Your app URL (should already be set)
NEXT_PUBLIC_APP_URL=http://localhost:3000
